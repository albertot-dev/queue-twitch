    "@twurple/auth": "^8.1.3",
    "@twurple/eventsub-ws": "^8.1.3",
    "electron-store": "^11.0.2",
    "express": "^5.2.1",
    "open": "^11.0.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
